<Layout title="The Curator | Joel Maynard - Branding & Digital Design Wiz">

  <!-- Navigation (React Island) -->
  <Navigation client:load />

  <main class="pt-32">

    <!-- Hero Section -->
    <section class="max-w-[1440px] mx-auto px-8 md:px-16 pt-12 pb-24 grid md:grid-cols-2 items-center gap-16 overflow-hidden">
      <div class="order-2 md:order-1 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
        <h1 class="newsreader text-6xl md:text-8xl font-bold leading-[0.9] text-primary tracking-tight">
          Joel Maynard — Branding &amp; Digital Design Wiz
        </h1>
        <div class="mt-12 flex items-center gap-4 group cursor-pointer">
          <div class="w-16 h-[1px] bg-primary/30 group-hover:w-24 transition-all duration-500"></div>
          <span class="inter text-sm uppercase tracking-widest font-semibold text-primary/60">Based in the UK</span>
        </div>
      </div>
      <div class="order-1 md:order-2 relative animate-fade-up" style="animation-delay: 0.3s; opacity: 0;">
        <div class="absolute inset-0 bg-surface-container-high rounded-[40px] -rotate-3 scale-105 -z-10"></div>
        <img
          alt="Creative Designer"
          class="w-full h-auto rounded-[32px] object-cover shadow-xl grayscale contrast-125"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3Dfm_nF6zot5hZucut2-CkyTQ0-JQprRRc-3eY_B-AlisT8LnTMrFHSAVuk3EgTE1BQLIfaj-4qDCkjqZACP-70X35hB93plyBaZLkBnlXHkYc6jsRCpla7jK3dEDWD-Qrohpj_uaSy6Z3lTdRNVguMyyi7j5cJ_egfPwuS49yJvFPqIs0RZO1zAT3ttALvmSKyZR_zJTMtPMtGXZiuekHIPgYDKbIOXqg2fTZ3TBYArdtLkFkl8DvjvtbDh894t8p51WHA6OOLUE"
        />
        <!-- Abstract Doodle -->
        <div class="absolute -bottom-10 -right-10 w-32 h-32 text-primary opacity-20">
          <span class="material-symbols-outlined text-[120px]">brush</span>
        </div>
      </div>
    </section>

    <!-- Intro / Philosophy Section -->
    <section class="bg-surface-container-low py-32 reveal">
      <div class="max-w-[1440px] mx-auto px-8 md:px-16">
        <div class="max-w-4xl">
          <p class="newsreader italic text-3xl text-primary/60 mb-8">The Philosophy</p>
          <h2 class="inter text-4xl md:text-5xl font-medium leading-relaxed text-primary">
            Hey, I'm Joel. A UK based creative who specialises in producing
            <span class="newsreader italic text-surface-tint">magical</span>
            brand experiences. I enjoy exploring unique ideas with forward thinking people.
          </h2>
        </div>
      </div>
    </section>

    <!-- Portfolio Staggered Grid -->
    <section class="max-w-[1440px] mx-auto px-8 md:px-16 py-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-y-32 gap-x-12">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            category={project.category}
            image={project.image}
            imageAlt={project.imageAlt}
            colSpan={project.colSpan}
            offsetTop={project.offsetTop}
            aspectRatio={project.aspectRatio}
          />
        ))}
      </div>
    </section>

    <!-- Let's Work Together Section -->
    <section class="max-w-[1440px] mx-auto px-8 md:px-16 py-32">
      <div class="bg-primary rounded-[64px] p-12 md:p-24 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12 reveal">
        <!-- Grain overlay -->
        <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/felt.png');"></div>
        <div class="relative z-10 max-w-xl">
          <h2 class="newsreader text-5xl md:text-7xl font-bold text-background mb-8 leading-tight">
            Let's work together
          </h2>
          <p class="inter text-on-primary-container text-xl mb-12">
            Currently accepting new projects for 2024. Reach out and let's build something magical.
          </p>
          <a
            class="inline-block bg-background text-primary px-12 py-5 rounded-full font-bold text-lg hover:scale-105 transition-transform duration-300"
            href="mailto:hello@mynrd.co.uk"
          >
            Get in Touch
          </a>
        </div>
        <div class="relative z-10 w-full max-w-md">
