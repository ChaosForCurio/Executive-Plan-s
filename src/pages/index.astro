---

<Layout title="Executive Plan">
  <Navigation client:load />

  <main>
    {/* Hero Section */}
    <section
      data-theme="light"
      class="min-h-screen flex flex-col justify-center items-center px-8 text-center pt-24 pb-48"
    >
      <div class="reveal active">
        <p
          class="inter text-xs uppercase tracking-[0.3em] font-bold text-secondary/40 mb-12"
        >
          Kota, Rajasthan, India • {new Date().getFullYear()}
        </p>
        <h1
          class="newsreader text-7xl md:text-[10rem] font-bold leading-[0.85] tracking-tight text-primary max-w-6xl mx-auto"
        >
          Branding & <br />
          <span class="italic text-secondary">Digital Wiz</span>
        </h1>
      </div>

      <div
        class="mt-24 flex flex-col items-center gap-6 reveal"
        style="transition-delay: 0.3s;"
      >
        <div class="w-[1px] h-32 bg-primary/10"></div>
        <p class="inter text-sm uppercase tracking-widest font-bold opacity-40">
          Scroll to Explore
        </p>
      </div>
    </section>

    {/* Philosophy / Intro */}
    <section
      id="intro"
      data-theme="white"
      class="relative bg-white text-[#0F3D3E] px-8 md:px-16 py-64 transition-colors duration-1000"
    >
      <TornEdge color="#FFFFFF" />
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-12">
        <div class="md:col-span-8 md:col-start-3 reveal">
          <h2
            class="newsreader text-4xl md:text-6xl font-medium leading-tight text-primary/80"
          >
            Hey, I'm Executive Plan. A creative specializing in
            <span class="italic text-primary">magical</span>
            brand experiences. I believe in bold ideas and disciplined execution.
          </h2>
        </div>
      </div>
    </section>

    {/* Portfolio Grid - Triggers Dark Theme */}
    <section
      id="portfolio"
      data-theme="dark"
      class="relative bg-[#003333] px-8 md:px-16 py-64 transition-colors duration-1000"
    >
      <TornEdge color="#003333" />
      <div class="max-w-[1440px] mx-auto">
        <div class="mb-32 reveal">
          <h3 class="newsreader text-2xl italic opacity-60 mb-4">
            Visual Summary
          </h3>
          <div class="w-full h-[1px] bg-primary/10"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-y-32 md:gap-x-16">
          {
            projects.map((project) => (
              <ProjectCard
                title={project.title}
                category={project.category}
                image={project.image}
                imageAlt={project.imageAlt}
                colSpan={project.colSpan}
                offsetTop={project.offsetTop}
                aspectRatio={project.aspectRatio}
                tilted={project.tilted}
              />
            ))
          }
        </div>
      </div>
    </section>

    {/* Let's Work Section */}
    <section
      id="contact"
      data-theme="light"
      class="relative bg-[#F5EFE6] text-[#0F3D3E] px-8 md:px-16 py-64 text-center transition-colors duration-1000"
    >
      <TornEdge color="#F5EFE6" />
      <div class="max-w-4xl mx-auto reveal">
        <h2
          class="newsreader text-6xl md:text-9xl font-bold leading-none mb-16"
        >
          Let's build <br />
          <span class="italic text-secondary">Something</span>
          <br />
          magical.
        </h2>
        <a
          href="mailto:hello@mynrd.co.uk"
          class="group relative inline-flex items-center justify-center px-12 py-6 overflow-hidden rounded-full border border-primary/10 transition-all duration-300 hover:border-primary"
        >
          <span
            class="relative z-10 inter font-bold text-xl uppercase tracking-widest"
            >Get in touch</span
          >
          <div
            class="absolute inset-0 bg-primary translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"
          >
          </div>
          <span
            class="absolute z-20 inter font-bold text-xl uppercase tracking-widest text-background translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"
            >Get in touch</span
          >
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Intersection Observer for scroll-triggered reveal animations
  const revealCallback = (entries: IntersectionObserverEntry[]) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("active");
      }
    });
  };

  const revealObserver = new IntersectionObserver(revealCallback, {
    threshold: 0.1,
  });

  document
    .querySelectorAll(".reveal")
    .forEach((el) => revealObserver.observe(el));

  // Theme Switcher Observer
  const themeObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const theme = entry.target.getAttribute("data-theme");
          if (theme) {
            document.body.setAttribute("data-theme", theme);
          }
        }
      });
    },
    {
      threshold: 0.25, // Wait until a quarter of the section is visible
    },
  );

  document.querySelectorAll("section[data-theme]").forEach((section) => {
    themeObserver.observe(section);
  });
</script>
