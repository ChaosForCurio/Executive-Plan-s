---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.jsx";
import ProjectCard from "../components/ProjectCard.astro";
import InteractiveServiceList from "../components/InteractiveServiceList.astro";
import Recognition from "../components/Recognition.astro";
import Newsletter from "../components/Newsletter.tsx";

const projects = [
  {
    title: "Prevail AI",
    category: "Branding / Web Design",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuAJd-JaLHCn7cVutPOnNe0kDuDV-aONwM0xJunRvRTYvR00FUeU0rKYaQpJ2dd3hzyAn3MWgc0HqZUvqN68kjKTt99Sg-4TPbXMA6YxOohGcrta3NH-kIX8ObSCSnIvYhFfP1qvpHmTuaAbXTw4sOh6VP4UhxvKqwXIvVfse3emtomHS7D4BabFfk5s__2P70f437VeFE5IKWJAYQEYPcnb95T0MabWT3Fm45sDaSDn3ctCxi6g9Xkd5oWgDFLe4nli5bqCxQJ-5zZY",
    imageAlt: "Prevail AI – Abstract digital art",
    colSpan: "md:col-span-12",
    aspectRatio: "aspect-[21/9]",
  },
  {
    title: "Flux Studio",
    category: "Product / UI Design",
    image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=900&q=80",
    imageAlt: "Flux Studio – colorful abstract art",
    colSpan: "md:col-span-11 md:ml-auto",
    aspectRatio: "aspect-[16/10]",
    offsetTop: "md:mt-48",
  },
  {
    title: "Northbound",
    category: "Identity / Motion",
    image: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&q=80",
    imageAlt: "Northbound – mountain landscape",
    colSpan: "md:col-span-7",
    aspectRatio: "aspect-square",
    offsetTop: "md:-mt-24",
  },
  {
    title: "Vanta Labs",
    category: "Strategy / Web",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=900&q=80",
    imageAlt: "Vanta Labs – tech abstract",
    colSpan: "md:col-span-12",
    aspectRatio: "aspect-[16/7]",
    offsetTop: "md:mt-32",
  },
];
---

<Layout title="Executive Plan — Creative Studio">
  <Navigation client:load />

  <main>
    {/* Hero */}
    <section class="min-h-[90vh] flex flex-col justify-center items-start px-8 md:px-16 pt-32 pb-48 relative overflow-hidden">
      <div class="inter text-[10px] uppercase tracking-[0.4em] text-primary/30 mb-12 font-bold animate-fade-in">
        Creative Studio — Based in India
      </div>
      
      <h1 id="hero-title" class="newsreader text-[12vw] md:text-[10vw] font-bold leading-[0.85] tracking-tighter mb-16 max-w-6xl">
        We craft <br />
        <span class="italic">unforgettable</span> <br />
        digital ideas.
      </h1>

      <div class="flex flex-col md:flex-row items-start md:items-end justify-between w-full gap-12">
        <p id="hero-desc" class="inter text-lg md:text-xl text-primary/60 max-w-sm leading-relaxed reveal">
          An independent studio building the next generation of brands through code, design, and strategic motion.
        </p>

        {/* Scroll hint */}
        <div class="flex flex-col items-center gap-4 opacity-20">
          <span class="inter text-[10px] uppercase tracking-[0.3em] font-bold">Explore Cases</span>
          <div class="w-px h-16 bg-primary animate-[height_2s_ease-in-out_infinite] origin-top"></div>
        </div>
      </div>
    </section>

    {/* Statement Section */}
    <section class="py-64 bg-primary text-background overflow-hidden relative">
      <div class="max-w-[1440px] mx-auto px-8 md:px-16">
        <h2 id="statement-text" class="newsreader text-[7vw] md:text-[6vw] font-bold leading-[1.1] tracking-tighter max-w-5xl">
          We believe that <span class="italic text-secondary">great design</span> isn't just about how it looks, it's about how it <span class="opacity-40">connects</span> strategy to human emotion.
        </h2>
      </div>
      
      {/* Marquee background effect */}
      <div class="mt-48 opacity-10 pointer-events-none select-none overflow-hidden">
        <div class="flex whitespace-nowrap animate-[marquee_20s_linear_infinite]">
          {Array(4).fill(0).map(() => (
            <span class="newsreader text-[15vw] font-bold uppercase tracking-tighter mr-20 shrink-0 italic">
              Strategy & Craft &middot; Digital Native &middot; Bold Vision &middot; 
            </span>
          ))}
        </div>
      </div>
    </section>

    {/* Interactive Service List */}
    <div class="py-48">
        <InteractiveServiceList />
    </div>

    {/* Projects Grid */}
    <section class="max-w-[1440px] mx-auto px-8 md:px-16 pb-64">
      <div class="flex justify-between items-end mb-32 reveal">
        <div class="inter text-[10px] uppercase tracking-[0.4em] text-primary/30 font-bold">
          Selected Cases
        </div>
        <div class="newsreader text-sm italic opacity-40">
           Curating Excellence Since 2024
        </div>
      </div>
      
      <div id="project-grid" class="grid grid-cols-1 md:grid-cols-12 gap-y-32 md:gap-y-64 gap-x-8 md:gap-x-12">
        {projects.map((project, index) => (
          <ProjectCard
            title={project.title}
            category={project.category}
            image={project.image}
            imageAlt={project.imageAlt}
            index={index}
            colSpan={project.colSpan}
            aspectRatio={project.aspectRatio}
            offsetTop={project.offsetTop ?? ""}
          />
        ))}
      </div>
    </section>

    {/* Recognition Bridge */}
    <Recognition />

    {/* Newsletter Section */}
    <Newsletter client:load />
  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    // Initial states to prevent jumps/stutter
    gsap.set(['#hero-title', '#hero-desc', '#statement-text', '.reveal'], { opacity: 0 });

    // Hero Title Reveal
    const heroTitle = new SplitType('#hero-title', { types: 'lines,words' });
    if (heroTitle.words) {
      gsap.set('#hero-title', { opacity: 1 }); // container visible, children hidden
      gsap.from(heroTitle.words, {
        y: '100%',
        opacity: 0,
        duration: 1.5,
        stagger: 0.05,
        ease: 'expo.out',
        delay: 0.3
      });
    }

    // Hero Desc Reveal
    const heroDesc = new SplitType('#hero-desc', { types: 'lines' });
    if (heroDesc.lines) {
      gsap.set('#hero-desc', { opacity: 1 });
      gsap.from(heroDesc.lines, {
          y: 20,
          opacity: 0,
          duration: 1.2,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.8
      });
    }

    // Statement Reveal on Scroll
    const statementText = new SplitType('#statement-text', { types: 'words' });
    if (statementText.words) {
      gsap.set('#statement-text', { opacity: 1 });
      gsap.from(statementText.words, {
        scrollTrigger: {
          trigger: '#statement-text',
          start: 'top 80%',
          end: 'bottom 40%',
          scrub: 1,
        },
        opacity: 0.1,
        y: 20,
        stagger: 0.1,
        ease: 'power3.out'
      });
    }

    // Projects stagger entrance
    const cards = document.querySelectorAll('.project-card-v2');
    cards.forEach((card) => {
        gsap.fromTo(card, 
            { y: 100, opacity: 0 },
            {
                scrollTrigger: {
                    trigger: card,
                    start: 'top 95%',
                    toggleActions: 'play none none none'
                },
                y: 0,
                opacity: 1,
                duration: 1.5,
                ease: 'expo.out'
            }
        );
    });

    // Simple reveals (excluding specifically animated sections)
    const reveals = document.querySelectorAll('.reveal:not(.project-card-v2)');
    reveals.forEach(el => {
        gsap.to(el, {
            scrollTrigger: {
                trigger: el,
                start: 'top 90%',
            },
            y: 0,
            opacity: 1,
            duration: 1,
            ease: 'power2.out',
            onStart: () => { gsap.set(el, { opacity: 1 }); } // Ensure visibility
        });
    });
  };

  // Run on load
  initAnimations();

  // Run after view transitions
  document.addEventListener('astro:after-swap', () => {
    initAnimations();
  });
</script>

<style is:global>
  @keyframes height {
    0%, 100% { transform: scaleY(0.4); opacity: 0.2; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .newsreader { font-family: "Newsreader", serif; }
  .inter { font-family: "Inter", sans-serif; }
  
  .ease-expo {
      transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
  }
</style>
