---
/* LenisLoader.astro - High Performance Smooth Scroll */
---

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initLenis = () => {
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      gestureOrientation: 'vertical',
      smoothWheel: true,
      wheelMultiplier: 1,
      touchMultiplier: 2,
      infinite: false,
    });

    lenis.on('scroll', ScrollTrigger.update);

    const onTick = (time: number) => {
      lenis.raf(time * 1000);
    };

    gsap.ticker.add(onTick);

    // Store the ticker function on the lenis instance for cleanup
    (lenis as any)._onTick = onTick;

    gsap.ticker.lagSmoothing(0);

    // Expose lenis to window for global access if needed
    // Using any cast to avoid conflict with existing global types
    (window as any).lenis = lenis;
  };

  // Initialize on load and on view transitions
  const start = () => {
    // Clean up existing instance if it exists to prevent leaks
    const oldLenis = (window as any).lenis;
    if (oldLenis) {
      if (oldLenis._onTick) {
        gsap.ticker.remove(oldLenis._onTick);
      }
      oldLenis.destroy();
    }
    initLenis();
  };

  start();
  document.addEventListener('astro:after-swap', start);
</script>

<style is:global>
  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }
  
  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }
</style>
