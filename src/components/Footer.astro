---
import TornEdge from "./TornEdge.astro";
const year = new Date().getFullYear();
---

<footer
  class="relative w-full bg-[#F2F1E8] text-[#0F3D3E] pt-48 pb-12 transition-colors duration-1000"
>
  <TornEdge color="#F2F1E8" />

  <div class="max-w-[1440px] mx-auto px-8 md:px-16">
    {/* Main CTA Section */}
    <div
      class="flex flex-col md:flex-row justify-between items-end gap-16 mb-48"
    >
      <div class="relative max-w-4xl group">
        {/* Floating Paper Plane Icon */}
        <div
          class="absolute -top-16 left-32 animate-bounce pointer-events-none opacity-60"
        >
          <svg
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </div>

        <a
          href="mailto:hello@mynrd.co.uk"
          class="newsreader text-7xl md:text-[8vw] font-bold leading-[0.9] tracking-tighter hover:italic transition-all duration-500 block"
        >
          Let's work <br /> together ↗
        </a>
      </div>

      {/* Illustration */}
      <div class="w-full max-w-sm relative">
        <img
          src="/juggling_globe_illustration.png"
          alt="Creative Illustration"
          class="w-full h-auto drop-shadow-2xl"
        />
      </div>
    </div>

    {/* Bottom Bar: 4 Column Grid */}
    <div
      class="grid grid-cols-1 md:grid-cols-4 gap-12 border-t border-[#0F3D3E]/10 pt-16 mt-32 items-center"
    >
      {/* Col 1: Copyright */}
      <div class="text-sm inter opacity-60">
        &copy; {year} &mdash; Executive Plan
      </div>

      {/* Col 2: Time & Location */}
      <div class="flex items-center gap-3 text-sm inter opacity-80">
        <span class="material-symbols-outlined text-[18px]">schedule</span>
        <span id="footer-clock" class="tabular-nums font-medium">00:00:00</span>
        <span class="opacity-40">Kota, Rajasthan, India</span>
      </div>

      {/* Col 3: Credits */}
      <div class="text-sm inter opacity-60">
        Made with ❤️ by <a
          href="https://github.com/ChaosForCurio?tab=repositories"
          class="border-b border-[#0F3D3E]/20 hover:border-[#0F3D3E]/60 transition-colors"
          >Ash Nayak</a
        >
      </div>

      {/* Col 4: Social Icons */}
      <div class="flex md:justify-end gap-8">
        <a href="#" class="opacity-60 hover:opacity-100 transition-opacity">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-12h2v6h-2zm0 8h2v2h-2z"
            ></path></svg
          >
        </a>
        <a href="#" class="opacity-60 hover:opacity-100 transition-opacity">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.584.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path></svg
          >
        </a>
        <a href="#" class="opacity-60 hover:opacity-100 transition-opacity">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  function updateTime() {
    const timeElement = document.getElementById("footer-clock");
    if (!timeElement) return;

    const options: Intl.DateTimeFormatOptions = {
      timeZone: "Europe/London",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    };

    timeElement.innerText = new Intl.DateTimeFormat("en-GB", options).format(
      new Date(),
    );
  }

  setInterval(updateTime, 1000);
  updateTime();
</script>
