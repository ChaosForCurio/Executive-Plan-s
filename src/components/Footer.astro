---
const year = new Date().getFullYear();
---

<footer
  id="main-footer"
  class="relative w-full bg-primary text-background pt-32 pb-12 overflow-hidden"
>
  {/* Large Background Brand Mark */}
  <div 
    id="footer-brand-mark"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 newsreader text-[40vw] font-bold opacity-[0.03] pointer-events-none whitespace-nowrap select-none"
  >
    EXECUTIVE PLAN
  </div>

  <div class="max-w-[1440px] mx-auto px-8 md:px-16 relative z-10">
    {/* High-End CTA Section */}
    <div class="mb-48 md:mb-64">
      <div class="inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-12 font-bold reveal-footer">
        Project Inquiry
      </div>
      <a
        href="mailto:hello@executiveplan.co"
        id="magnetic-link"
        class="group relative inline-block newsreader text-[10vw] md:text-[8vw] font-bold leading-[0.9] tracking-tighter"
      >
        <div class="line-reveal overflow-hidden">
          <span class="inline-block footer-title">Let's scale</span>
        </div>
        <div class="line-reveal overflow-hidden">
          <span class="inline-block footer-title italic">your vision.</span>
        </div>
        
        {/* Subtle hover underline */}
        <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-background group-hover:w-full transition-all duration-700 ease-expo"></div>
      </a>
    </div>

    {/* Main Grid */}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8 pt-16 border-t border-background/10">
      {/* Brand & Mission */}
      <div class="md:col-span-5 flex flex-col justify-between">
        <div>
          <div class="newsreader text-4xl font-bold mb-6">EP.</div>
          <p class="inter text-sm opacity-40 max-w-xs leading-relaxed">
            Crafting clinical identities and digital-first experiences for forward-thinking brands.
          </p>
        </div>
        <div class="mt-12 md:mt-0 pt-12 md:pt-0 border-t border-background/5 md:border-none">
            <div class="flex items-center gap-4">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></div>
                <span class="inter text-[10px] uppercase tracking-widest font-bold opacity-30">Studio Status: Always Online</span>
            </div>
        </div>
      </div>

      {/* Navigation */}
      <div class="md:col-span-2">
        <div class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-20 mb-8">Navigation</div>
        <ul class="flex flex-col gap-4">
          <li><a href="/" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Index</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Work</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Journal</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Contact</a></li>
        </ul>
      </div>

      {/* Social */}
      <div class="md:col-span-2">
        <div class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-20 mb-8">Connect</div>
        <ul class="flex flex-col gap-4">
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Instagram</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">LinkedIn</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Twitter / X</a></li>
          <li><a href="#" class="inter text-sm hover:opacity-100 opacity-50 transition-opacity">Awwwards</a></li>
        </ul>
      </div>

      {/* Location / Clock */}
      <div class="md:col-span-3 md:text-right flex flex-col md:items-end justify-between">
        <div class="text-left md:text-right">
          <div class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-20 mb-8">Local Time</div>
          <div id="footer-clock" class="newsreader text-5xl italic tabular-nums">00:00:00</div>
          <div class="inter text-[10px] uppercase tracking-widest opacity-30 mt-2">Rajasthan, India (IST)</div>
        </div>
      </div>
    </div>

    {/* Copyright & Legal */}
    <div class="mt-32 pt-12 border-t border-background/5 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="inter text-[9px] uppercase tracking-[0.3em] opacity-20 font-bold">
        &copy; {year} Executive Plan Strategy & Design. Built with passion.
      </div>
      <div class="flex gap-8 inter text-[9px] uppercase tracking-[0.3em] opacity-20 font-bold">
        <a href="#" class="hover:opacity-100 transition-opacity">Privacy Policy</a>
        <a href="#" class="hover:opacity-100 transition-opacity">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  const initFooter = () => {
    // 1. Clock Update
    const updateTime = () => {
      const timeElement = document.getElementById("footer-clock");
      if (!timeElement) return;
      const options: Intl.DateTimeFormatOptions = {
        timeZone: "Asia/Kolkata",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      };
      timeElement.innerText = new Intl.DateTimeFormat("en-GB", options).format(new Date());
    };
    setInterval(updateTime, 1000);
    updateTime();

    // 2. Magnetic Effect
    const magneticLink = document.getElementById('magnetic-link');
    if (magneticLink) {
      magneticLink.addEventListener('mousemove', (e) => {
        const bounds = magneticLink.getBoundingClientRect();
        const x = e.clientX - bounds.left - bounds.width / 2;
        const y = e.clientY - bounds.top - bounds.height / 2;
        
        gsap.to(magneticLink, {
          x: x * 0.3,
          y: y * 0.3,
          duration: 0.6,
          ease: 'power2.out'
        });
      });

      magneticLink.addEventListener('mouseleave', () => {
        gsap.to(magneticLink, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: 'elastic.out(1, 0.3)'
        });
      });
    }

    // 3. Brand Mark Scroll Parallax
    gsap.to('#footer-brand-mark', {
      scrollTrigger: {
        trigger: '#main-footer',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1
      },
      scale: 1.2,
      opacity: 0.08,
      ease: 'none'
    });

    // 4. Content Reveals
    const footerTitles = new SplitType('.footer-title', { types: 'chars' });
    if (footerTitles.chars) {
        gsap.from(footerTitles.chars, {
            scrollTrigger: {
                trigger: '#main-footer',
                start: 'top 60%',
            },
            y: 100,
            opacity: 0,
            stagger: 0.02,
            duration: 1,
            ease: 'expo.out'
        });
    }

    const reveals = document.querySelectorAll('.reveal-footer');
    gsap.from(reveals, {
        scrollTrigger: {
            trigger: '#main-footer',
            start: 'top 70%',
        },
        y: 20,
        opacity: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out'
    });
  };

  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>

<style>
  .newsreader { font-family: "Newsreader", serif; }
  .inter { font-family: "Inter", sans-serif; }
  .ease-expo { transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1); }
</style>
