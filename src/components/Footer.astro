---
const year = new Date().getFullYear();
---

<footer
  id="main-footer"
  class="relative w-full bg-primary text-background overflow-hidden rounded-t-[2.5rem] lg:rounded-t-[4rem] -mt-[2.5rem] lg:-mt-[4rem] z-20"
>
  <div class="max-w-[1600px] mx-auto px-6 md:px-12 pt-24 md:pt-32 lg:pt-40 relative z-10">
    
    {/* Top Section: CTA & Contact */}
    <div class="flex flex-col lg:flex-row justify-between items-start gap-16 mb-24 lg:mb-40">
      
      {/* Huge CTA */}
      <div class="w-full lg:w-2/3">
        <div class="inter text-[10px] md:text-xs uppercase tracking-[0.4em] opacity-50 mb-8 md:mb-12 font-bold footer-reveal-up">
          <span class="inline-block w-2 h-2 rounded-full bg-green-500 mr-3 animate-pulse"></span>
          Accepting New Projects
        </div>
        
        <h2 class="newsreader text-[12vw] lg:text-[8vw] font-medium leading-[0.85] tracking-tight mb-12">
          <div class="overflow-hidden pb-2">
            <span class="inline-block footer-title-word">Let's craft</span>
          </div>
          <div class="overflow-hidden pb-2">
            <span class="inline-block footer-title-word italic opacity-80">your digital</span>
          </div>
          <div class="overflow-hidden pb-2">
            <span class="inline-block footer-title-word">legacy.</span>
          </div>
        </h2>
        
        <a href="mailto:hello@executiveplan.co" class="magnetic-btn group relative inline-flex items-center justify-center w-32 h-32 md:w-40 md:h-40 rounded-full border border-background/20 hover:bg-background hover:text-primary transition-colors duration-500 footer-reveal-up">
          <span class="inter text-xs uppercase tracking-widest font-bold z-10 group-hover:-translate-y-1 group-hover:-translate-x-1 transition-transform duration-300">Get in touch</span>
          <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 opacity-0 group-hover:opacity-100 group-hover:translate-x-4 group-hover:translate-y-4 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      {/* Info & Links Grid */}
      <div class="w-full lg:w-1/3 grid grid-cols-2 gap-x-8 gap-y-16">
        <div class="footer-reveal-up">
          <h4 class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-30 mb-6">Navigation</h4>
          <ul class="flex flex-col gap-3">
            <li><a href="/" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Index</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Work</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Journal</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Contact</a></li>
          </ul>
        </div>
        
        <div class="footer-reveal-up">
          <h4 class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-30 mb-6">Socials</h4>
          <ul class="flex flex-col gap-3">
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Instagram</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">LinkedIn</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Twitter</a></li>
            <li><a href="#" class="inter text-sm hover:opacity-100 opacity-60 hover:translate-x-2 transition-all duration-300 inline-block">Awwwards</a></li>
          </ul>
        </div>

        <div class="footer-reveal-up col-span-2 md:col-span-1">
          <h4 class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-30 mb-6">Studio Location</h4>
          <p class="inter text-sm opacity-60 leading-relaxed">
            Rajasthan, India<br/>
            Operating globally
          </p>
        </div>

        <div class="footer-reveal-up col-span-2 md:col-span-1">
          <h4 class="inter text-[10px] uppercase tracking-[0.3em] font-bold opacity-30 mb-6">Local Time</h4>
          <div id="footer-clock" class="newsreader text-3xl italic tracking-tight">00:00:00</div>
          <div class="inter text-[10px] uppercase tracking-widest opacity-40 mt-1">IST</div>
        </div>
      </div>
    </div>

    {/* Massive Edge-to-Edge Text */}
    <div class="w-full border-t border-background/10 pt-12 lg:pt-16 overflow-hidden flex flex-col items-center">
      <div id="massive-text" class="newsreader font-medium tracking-tighter leading-none text-[15vw] whitespace-nowrap opacity-90 select-none">
        EXECUTIVE
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="w-full pb-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 border-t border-background/10 mt-8">
      <div class="inter text-[10px] uppercase tracking-[0.2em] opacity-40 font-semibold">
        &copy; {year} Executive Plan Strategy & Design
      </div>
      <div class="flex gap-8 inter text-[10px] uppercase tracking-[0.2em] opacity-40 font-semibold">
        <a href="#" class="hover:opacity-100 transition-opacity">Privacy Policy</a>
        <a href="#" class="hover:opacity-100 transition-opacity">Terms of Service</a>
      </div>
    </div>
    
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initFooter = () => {
    // 1. Clock Update
    const updateTime = () => {
      const timeElement = document.getElementById("footer-clock");
      if (!timeElement) return;
      const options: Intl.DateTimeFormatOptions = {
        timeZone: "Asia/Kolkata",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      };
      timeElement.innerText = new Intl.DateTimeFormat("en-GB", options).format(new Date());
    };
    setInterval(updateTime, 1000);
    updateTime();

    // 2. Magnetic Buttons Effect
    const magneticBtns = document.querySelectorAll('.magnetic-btn');
    magneticBtns.forEach((btn) => {
      btn.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const target = mouseEvent.currentTarget as HTMLElement;
        const bounds = target.getBoundingClientRect();
        
        // Calculate distance from center
        const x = mouseEvent.clientX - bounds.left - bounds.width / 2;
        const y = mouseEvent.clientY - bounds.top - bounds.height / 2;
        
        // Move button slightly towards mouse
        gsap.to(target, {
          x: x * 0.4,
          y: y * 0.4,
          duration: 0.6,
          ease: 'power3.out'
        });
      });

      btn.addEventListener('mouseleave', (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        // Snap back to original position
        gsap.to(target, {
          x: 0,
          y: 0,
          duration: 1,
          ease: 'elastic.out(1, 0.3)'
        });
      });
    });

    // 3. Scroll Animations
    
    // Animate large text upwards smoothly
    gsap.fromTo('.footer-title-word', 
      { y: 150, opacity: 0, rotate: 5 },
      {
        y: 0,
        opacity: 1,
        rotate: 0,
        stagger: 0.1,
        duration: 1.5,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: '#main-footer',
          start: 'top 70%',
        }
      }
    );

    // Reveal other elements with slight delay
    gsap.fromTo('.footer-reveal-up',
      { y: 50, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        stagger: 0.05,
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#main-footer',
          start: 'top 75%',
        }
      }
    );

    // Massive Text Parallax & Scale
    gsap.fromTo('#massive-text',
      { y: 100, scale: 0.9, opacity: 0 },
      {
        y: 0,
        scale: 1,
        opacity: 1,
        duration: 2,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: '#main-footer',
          start: 'top 80%',
          end: 'bottom bottom',
          scrub: 1
        }
      }
    );
  };

  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>

<style>
  .newsreader { font-family: "Newsreader", serif; }
  .inter { font-family: "Inter", sans-serif; }
  
  /* Custom clip path for the top of the footer for an extra flair if desired */
  /* #main-footer {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  } */
</style>
